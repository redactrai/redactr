# Redactr server deployment configuration.
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# Every value here is read by docker-compose and/or redactr-server.

# ---------------------------------------------------------------------------
# Domain + public URL
# ---------------------------------------------------------------------------
# The public DNS name pointed at this host. Caddy provisions a TLS cert for it
# automatically via ACME (Let's Encrypt). Port 80 and 443 must be reachable.
REDACTR_DOMAIN=redactr.example.com

# External https base URL. docker-compose derives this as https://$REDACTR_DOMAIN,
# so you normally do NOT need to set it here. Override only for unusual setups.
# REDACTR_PUBLIC_URL=https://redactr.example.com

# ---------------------------------------------------------------------------
# Admin authentication — configure superadmin and/or OIDC (at least one).
# ---------------------------------------------------------------------------
# Superadmin username for password login.
REDACTR_SUPERADMIN_USER=admin

# bcrypt hash of the superadmin password (PREFERRED — never commit plaintext).
# Generate one (cost 12) with either:
#   htpasswd -bnBC 12 "" 'your-password' | tr -d ':\n'
#   docker run --rm httpd:2 htpasswd -bnBC 12 "" 'your-password' | tr -d ':\n'
# or a Go one-liner — see README.md.
REDACTR_SUPERADMIN_PASSWORD_HASH=$2y$12$replace.with.a.real.bcrypt.hash.value.here.padding

# Alternative: supply a plaintext password and the server will bcrypt-hash it at
# startup (logs a warning). Prefer the HASH above for production.
# REDACTR_SUPERADMIN_PASSWORD=change-me

# OIDC single sign-on (optional). Set all three of issuer/client-id/secret to
# enable. The redirect URL defaults to https://$REDACTR_DOMAIN/admin/oidc/callback
# if left unset — register that exact URL with your IdP.
# REDACTR_OIDC_ISSUER=https://accounts.example.com
# REDACTR_OIDC_CLIENT_ID=your-client-id
# REDACTR_OIDC_CLIENT_SECRET=your-client-secret
# REDACTR_OIDC_REDIRECT_URL=https://redactr.example.com/admin/oidc/callback

# ---------------------------------------------------------------------------
# Sessions + automation
# ---------------------------------------------------------------------------
# Admin session lifetime (Go duration). Default 12h.
REDACTR_SESSION_TTL=12h

# Optional machine key: allows CI/automation to mint enrollment tokens via the
# X-Machine-Key header (the only endpoint that honors it). Leave unset to disable.
# Generate a strong random value, e.g.: openssl rand -base64 32
# REDACTR_MACHINE_KEY=

# ---------------------------------------------------------------------------
# Retention + limits
# ---------------------------------------------------------------------------
# Nightly SQLite backups: how many to keep (>=1). Default 14.
REDACTR_BACKUP_RETAIN=14
# Delete audit/event rows older than this many days (>=1). Default 365.
REDACTR_AUDIT_RETAIN_DAYS=365
# Max request body size in bytes (>0). Default 1048576 (1 MiB).
REDACTR_MAX_BODY_BYTES=1048576

# ---------------------------------------------------------------------------
# Image building (optional; requires docker + cosign in the server image).
# ---------------------------------------------------------------------------
# Container registry base for built org images. Leave unset to disable building.
# REDACTR_REGISTRY=registry.example.com
# Path to the cosign signing key. Default ./keys/cosign.key.
# REDACTR_COSIGN_KEY=/data/keys/cosign.key

# ---------------------------------------------------------------------------
# Dev mode (DO NOT enable in production)
# ---------------------------------------------------------------------------
# When "1"/"true": skips https + auth validation and marks cookies non-Secure.
# REDACTR_DEV_MODE=
